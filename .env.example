PORT=3000
HOST=0.0.0.0

# Public-source clients
NCBI_TOOL=omics_bharat
NCBI_EMAIL=
OUTBOUND_USER_AGENT=OmicsBharat/3.0 (public-and-commercial research workspace)

# Commercial workspace modes: demo | production | off
COMMERCIAL_MODE=demo
COMMERCIAL_DEMO=true

# Required outside demo mode. Generate a long random secret and store it in a secrets manager.
OMICS_SESSION_SECRET=
OMICS_SESSION_TTL_HOURS=12

# First production administrator. Replace the bootstrap flow with managed OIDC/SAML before enterprise use.
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=

# Optional durable file adapter for a single-node evaluation deployment.
# Do not use this adapter as the final enterprise database architecture.
OMICS_DATA_DIR=

# Workflow execution: manifest | webhook
WORKFLOW_EXECUTOR=manifest
WORKFLOW_WEBHOOK_URL=
WORKFLOW_WEBHOOK_SECRET=

# Private human genomic data is rejected unless an approved deployment explicitly enables it.
ALLOW_PRIVATE_HUMAN_DATA=false
DEPLOYMENT_REGION=unspecified
SUPPORT_CONTACT=support@omicsbharat.example
